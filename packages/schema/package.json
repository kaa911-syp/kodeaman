{
  "name": "@aspidasec/schema",
  "version": "0.1.0",
  "description": "Canonical NormalizedFinding schema for AspidaSec security coach",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
