{
  "name": "@aspidasec/watcher",
  "version": "0.1.0",
  "description": "File watcher for real-time AspidaSec scans",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aspidasec/core": "workspace:*",
    "@aspidasec/config": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kaa911-syp/AspidaSec.git",
    "directory": "packages/watcher"
  },
  "homepage": "https://github.com/kaa911-syp/AspidaSec#readme",
  "bugs": {
    "url": "https://github.com/kaa911-syp/AspidaSec/issues"
  },
  "keywords": [
    "aspidasec",
    "security",
    "watch",
    "filesystem"
  ]
}
