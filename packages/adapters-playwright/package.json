{
  "name": "@aspidasec/adapters-playwright",
  "version": "0.1.0",
  "description": "Playwright DAST scanner adapter for AspidaSec",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aspidasec/schema": "workspace:*"
  },
  "peerDependencies": {
    "playwright": "^1.49.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kaa911-syp/AspidaSec.git",
    "directory": "packages/adapters-playwright"
  },
  "homepage": "https://github.com/kaa911-syp/AspidaSec#readme",
  "bugs": {
    "url": "https://github.com/kaa911-syp/AspidaSec/issues"
  },
  "keywords": [
    "aspidasec",
    "security",
    "playwright",
    "dast",
    "browser"
  ]
}
