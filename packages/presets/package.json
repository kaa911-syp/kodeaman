{
  "name": "@aspidasec/presets",
  "version": "0.1.0",
  "description": "Framework presets for AspidaSec \u00e2\u20ac\u201d Laravel, Node/Express, WordPress",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vibellabbs-code/aspidasec.git",
    "directory": "packages/presets"
  },
  "homepage": "https://github.com/vibellabbs-code/aspidasec#readme",
  "bugs": {
    "url": "https://github.com/vibellabbs-code/aspidasec/issues"
  },
  "keywords": [
    "aspidasec",
    "security",
    "presets",
    "frameworks",
    "laravel",
    "express"
  ]
}
