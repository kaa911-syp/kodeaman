{
  "name": "@aspidasec/lessons",
  "version": "0.1.0",
  "description": "Security micro-lessons for AspidaSec coaching (bilingual en/id)",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
