{
  "name": "aspidasec-vscode-extension",
  "displayName": "AspidaSec",
  "description": "Run AspidaSec security scans and view findings as VS Code diagnostics.",
  "version": "0.1.0",
  "publisher": "aspidasec",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onCommand:aspidasec.scanWorkspace",
    "onCommand:aspidasec.clearDiagnostics"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aspidasec.scanWorkspace",
        "title": "AspidaSec: Scan Workspace"
      },
      {
        "command": "aspidasec.clearDiagnostics",
        "title": "AspidaSec: Clear Diagnostics"
      }
    ],
    "configuration": {
      "title": "AspidaSec",
      "properties": {
        "aspidasec.cliPath": {
          "type": "string",
          "default": "aspidasec",
          "description": "Path to the AspidaSec CLI executable."
        },
        "aspidasec.scanFormat": {
          "type": "string",
          "enum": ["json"],
          "default": "json",
          "description": "Output format requested from the AspidaSec CLI. The extension currently expects JSON."
        },
        "aspidasec.maxBuffer": {
          "type": "number",
          "default": 10485760,
          "description": "Maximum stdout buffer in bytes for AspidaSec scan output."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc --noEmit -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.6.0"
  }
}
