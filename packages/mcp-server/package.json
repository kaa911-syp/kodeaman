{
  "name": "@aspidasec/mcp-server",
  "version": "0.1.0",
  "description": "MCP (Model Context Protocol) server for AspidaSec security coach \u00e2\u20ac\u201d enables AI coding assistants to perform security scanning",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "aspidasec-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@aspidasec/config": "workspace:*",
    "@aspidasec/core": "workspace:*",
    "@aspidasec/schema": "workspace:*",
    "@aspidasec/owasp": "workspace:*",
    "@aspidasec/adapters-semgrep": "workspace:*",
    "@aspidasec/adapters-zap": "workspace:*",
    "@aspidasec/adapters-npm-audit": "workspace:*",
    "@aspidasec/adapters-playwright": "workspace:*",
    "@aspidasec/output-sarif": "workspace:*",
    "@aspidasec/output-html": "workspace:*",
    "@aspidasec/output-markdown": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vibellabbs-code/aspidasec.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/vibellabbs-code/aspidasec#readme",
  "bugs": {
    "url": "https://github.com/vibellabbs-code/aspidasec/issues"
  },
  "keywords": [
    "aspidasec",
    "security",
    "mcp",
    "model-context-protocol",
    "ai-assistant"
  ]
}
