{
  "name": "@aspidasec/adapters-cargo-audit",
  "version": "0.1.0",
  "description": "cargo-audit Rust SCA scanner adapter for AspidaSec",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aspidasec/core": "workspace:*",
    "@aspidasec/schema": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vibellabbs-code/aspidasec.git",
    "directory": "packages/adapters-cargo-audit"
  },
  "homepage": "https://github.com/vibellabbs-code/aspidasec#readme",
  "bugs": {
    "url": "https://github.com/vibellabbs-code/aspidasec/issues"
  },
  "keywords": [
    "aspidasec",
    "security",
    "cargo-audit",
    "sca",
    "adapter"
  ]
}
