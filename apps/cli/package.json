{
  "name": "@aspidasec/cli",
  "version": "0.1.0",
  "description": "CLI for AspidaSec security coach",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "aspidasec": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aspidasec/config": "workspace:*",
    "@aspidasec/core": "workspace:*",
    "@aspidasec/history": "workspace:*",
    "@aspidasec/schema": "workspace:*",
    "@aspidasec/adapters-semgrep": "workspace:*",
    "@aspidasec/adapters-zap": "workspace:*",
    "@aspidasec/adapters-npm-audit": "workspace:*",
    "@aspidasec/adapters-playwright": "workspace:*",
    "@aspidasec/owasp": "workspace:*",
    "@aspidasec/prioritizer": "workspace:*",
    "@aspidasec/coaching": "workspace:*",
    "@aspidasec/gamification": "workspace:*",
    "@aspidasec/output-markdown": "workspace:*",
    "@aspidasec/output-html": "workspace:*",
    "@aspidasec/output-sarif": "workspace:*",
    "@aspidasec/presets": "workspace:*",
    "@aspidasec/watcher": "workspace:*",
    "@aspidasec/autofix": "workspace:*",
    "@aspidasec/custom-rules": "workspace:*",
    "@aspidasec/dashboard": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vibellabbs-code/aspidasec.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/vibellabbs-code/aspidasec#readme",
  "bugs": {
    "url": "https://github.com/vibellabbs-code/aspidasec/issues"
  },
  "keywords": [
    "aspidasec",
    "security",
    "cli",
    "command-line",
    "scanner"
  ]
}
